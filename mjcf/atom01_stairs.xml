<mujoco model="atom01">
<compiler angle="radian" meshdir="../meshes/" eulerseq="zyx"/>
<option timestep="0.001" iterations="100" solver="PGS" gravity="0 0 -9.81">
<flag frictionloss="enable"/>
</option>
<size njmax="5000" nconmax="1000"/>
<visual>
<quality shadowsize="4096"/>
<map znear="0.001" zfar="50"/>
</visual>
<default>
<joint limited="true"/>
<motor ctrllimited="true"/>
<geom condim="4" contype="1" conaffinity="0" solref="0.001 2" friction="0.9 0.2 0.2" group="1"/>
